---
import MainLayout from '../layouts/MainLayout.astro';

---

<MainLayout title="EduCrow - Learn, Code, Grow">
  <div class="min-h-screen flex flex-col items-center justify-center bg-gradient-to-br from-indigo-500 to-purple-600 text-white p-4">
    <div class="max-w-4xl w-full text-center">
      <h1 class="text-6xl font-bold mb-6 animate-fade-in">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-purple-200">EduCrow</span>
      </h1>
      <p class="text-xl mb-12 text-purple-100 max-w-2xl mx-auto">
        Your comprehensive learning platform for mastering programming. Join our community of developers, access curated coding challenges, and enhance your skills with expert-led tutorials.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
        <a 
          href="/signin" 
          class="px-8 py-3 bg-white text-purple-600 rounded-full font-semibold text-lg hover:bg-purple-100 transition-colors duration-300 min-w-[160px]"
        >
          Sign In
        </a>
        <a 
          href="/signup" 
          class="px-8 py-3 bg-purple-700 text-white rounded-full font-semibold text-lg hover:bg-purple-800 transition-colors duration-300 min-w-[160px] border-2 border-purple-400"
        >
          Sign Up
        </a>
      </div>

      <div class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-5xl mx-auto">
        <div class="bg-white/10 backdrop-blur-lg rounded-xl p-6 text-center hover:bg-white/20 transition-colors duration-300">
          <div class="text-4xl mb-4">💻</div>
          <h3 class="text-xl font-semibold mb-2">Coding Challenges</h3>
          <p class="text-purple-100">Practice with real-world programming problems</p>
        </div>
        <div class="bg-white/10 backdrop-blur-lg rounded-xl p-6 text-center hover:bg-white/20 transition-colors duration-300">
          <div class="text-4xl mb-4">📚</div>
          <h3 class="text-xl font-semibold mb-2">Learning Resources</h3>
          <p class="text-purple-100">Access comprehensive tutorials and guides</p>
        </div>
        <div class="bg-white/10 backdrop-blur-lg rounded-xl p-6 text-center hover:bg-white/20 transition-colors duration-300">
          <div class="text-4xl mb-4">👥</div>
          <h3 class="text-xl font-semibold mb-2">Community</h3>
          <p class="text-purple-100">Connect with fellow developers</p>
        </div>
        <div class="bg-white/10 backdrop-blur-lg rounded-xl p-6 text-center hover:bg-white/20 transition-colors duration-300">
          <div class="text-4xl mb-4">🎯</div>
          <h3 class="text-xl font-semibold mb-2">Track Progress</h3>
          <p class="text-purple-100">Monitor your learning journey</p>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s ease-out;
  }
</style>