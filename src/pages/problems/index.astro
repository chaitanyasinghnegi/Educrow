---
import MainLayout from '../../layouts/MainLayout.astro';
import { supabase } from '../../utils/supabaseClient';

// Fetch problems from Supabase
const { data: problems, error } = await supabase
  .from('problems')
  .select(`
    *,
    examples (*)
  `)
  .order('id', { ascending: true });

if (error) {
  console.error('Error fetching problems:', error);
}
---

<MainLayout title="Coding Problems">
  <h1 class="text-3xl font-bold mb-8">Coding Problems</h1>
  <div class="grid gap-4">
    {problems?.map(problem => (
      <a href={`/problems/${problem.id}`} class="block p-4 bg-white rounded-lg shadow hover:shadow-md">
        <div class="flex justify-between items-center">
          <h3 class="text-xl font-semibold">{problem.title}</h3>
          <span class={`px-3 py-1 rounded text-sm ${
            problem.difficulty === 'Easy' ? 'bg-green-100 text-green-800' :
            problem.difficulty === 'Medium' ? 'bg-yellow-100 text-yellow-800' :
            'bg-red-100 text-red-800'
          }`}>
            {problem.difficulty}
          </span>
        </div>
        <p class="text-gray-600 mt-2">{problem.description}</p>
      </a>
    ))}
  </div>
</MainLayout>

