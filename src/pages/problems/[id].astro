---
import MainLayout from '../../layouts/MainLayout.astro';
import { supabase } from '../../utils/supabaseClient';
import CodeEditor from '../../components/CodeEditor';

export async function getStaticPaths() {
  const { data: problems, error } = await supabase
    .from('problems')
    .select('id')
    .order('id', { ascending: true });

  if (error) {
    console.error('Error fetching paths:', error);
    return [];
  }

  return problems.map(problem => ({
    params: { id: problem.id.toString() },
  }));
}

const { id } = Astro.params;

// Fetch single problem with examples
const { data: problemData, error } = await supabase
  .from('problems')
  .select(`
    *,
    examples (*)
  `)
  .eq('id', id)
  .single();

if (error || !problemData) {
  return new Response(null, {
    status: 404,
    statusText: 'Problem not found'
  });
}

const problem = {
  ...problemData,
  examples: problemData.examples || []
};
---

<MainLayout title={problem.title}>
  <div class="w-full px-4">
    <div class="mb-8">
      <div class="flex items-center gap-4 mb-4">
        <a href="/problems" class="text-indigo-600 hover:text-indigo-800">← Back to Problems</a>
        <h1 class="text-3xl font-bold">{problem.title}</h1>
        <span class={`px-3 py-1 rounded-full text-sm ${
          problem.difficulty === 'Easy' ? 'bg-green-100 text-green-800' :
          problem.difficulty === 'Medium' ? 'bg-yellow-100 text-yellow-800' :
          'bg-red-100 text-red-800'
        }`}>
          {problem.difficulty}
        </span>
      </div>
      
      <div class="bg-white rounded-lg shadow-md p-6 mb-6">
        <p class="text-gray-700 mb-4">{problem.description}</p>
        
        <h3 class="font-semibold mb-2">Examples:</h3>
        {problem.examples.map(example => (
          <div class="bg-gray-50 p-4 rounded-lg mb-4">
            <p class="font-mono mb-2">Input: {example.input}</p>
            <p class="font-mono mb-2">Output: {example.output}</p>
            {example.explanation && (
              <p class="text-gray-600">Explanation: {example.explanation}</p>
            )}
          </div>
        ))}
      </div>
    </div>
     
    <CodeEditor client:load />
  </div>
</MainLayout>

