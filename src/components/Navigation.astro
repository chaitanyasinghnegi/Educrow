---
const links = [
  { href: '/index_org', text: 'Home' },
  { href: '/problems', text: 'Problems' },
  { href: '/chatbot', text: 'AI Help' },
  { href: '/videos', text: 'Videos' },
  { href: '/cheatsheets', text: 'Cheat Sheets' },
];
---

<nav class="bg-white shadow-lg">
  <div class="container mx-auto px-4">
    <div class="flex justify-between items-center h-16">
      <a href="/index_org" class="text-xl font-bold text-indigo-600">EduCrow</a>
      <div class="hidden md:flex space-x-8 items-center">
        {links.map(link => (
          <a href={link.href} class="text-gray-700 hover:text-indigo-600 transition-colors">{link.text}</a>
        ))}
        <button id="sign-out-btn" class="ml-4 px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700 transition-colors">
          Sign Out
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  const signOutBtn = document.getElementById('sign-out-btn');
  signOutBtn?.addEventListener('click', () => {
    sessionStorage.removeItem('userData');
    sessionStorage.removeItem('userSession');
    window.location.href = '/';
  });
</script>
