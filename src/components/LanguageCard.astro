---
import type { ProgrammingLanguage } from '../data/programming-languages';

interface Props {
  language: ProgrammingLanguage;
}

const { language } = Astro.props;
---

<a href={`/videos/${language.id}`} class="block p-6 bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow">
  <div class="text-4xl mb-4">{language.icon}</div>
  <h3 class="text-xl font-semibold text-gray-800 mb-2">{language.name}</h3>
  <p class="text-gray-600">{language.description}</p>
</a>