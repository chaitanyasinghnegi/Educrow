---
interface Props {
  href: string;
  icon: string;
  name: string;
}

const { href, icon, name } = Astro.props;
---

<a 
  href={href}
  class="animated-button group relative overflow-hidden rounded-lg bg-white p-8 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
>
  <div class="relative z-10 flex flex-col items-center text-center">
    <span class="text-6xl mb-4 transform transition-transform duration-300 group-hover:scale-110">
      {icon}
    </span>
    <h3 class="text-2xl font-bold text-gray-800 mb-3">{name}</h3>
    <span class="inline-flex items-center gap-2 rounded-full bg-indigo-100 px-4 py-2 text-sm font-medium text-indigo-700 transition-colors duration-300 group-hover:bg-indigo-200">
      View Tutorials
      <span class="transform transition-transform duration-300 group-hover:translate-x-1">→</span>
    </span>
  </div>
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-indigo-50 via-white to-indigo-100 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
</a>

<style>
  .animated-button {
    animation: fadeIn 0.5s ease-out backwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>