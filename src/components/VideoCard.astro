---
import type { VideoTutorial } from '../data/video-tutorials';

interface Props {
  video: VideoTutorial;
  index: number;
}

const { video, index } = Astro.props;
---

<div 
  class="video-card bg-white rounded-lg shadow-md overflow-hidden transform hover:-translate-y-1 transition-all duration-300"
  style={`--delay: ${index * 100}ms`}
  data-video-difficulty={video.difficulty}
>
  <img src={video.thumbnail} alt={video.title} class="w-full h-48 object-cover" />
  <div class="p-6">
    <div class="flex justify-between items-start mb-3">
      <h3 class="text-xl font-semibold text-gray-800">{video.title}</h3>
      <span class={`px-3 py-1 rounded-full text-sm ${
        video.difficulty === 'Beginner' ? 'bg-green-100 text-green-800' :
        video.difficulty === 'Intermediate' ? 'bg-yellow-100 text-yellow-800' :
        'bg-red-100 text-red-800'
      }`}>
        {video.difficulty}
      </span>
    </div>
    <p class="text-gray-600 mb-4">{video.description}</p>
    <div class="flex justify-between items-center">
      <span class="text-sm text-gray-500">{video.duration}</span>
      <button class="text-indigo-600 hover:text-indigo-800">
        Watch Now →
      </button>
    </div>
  </div>
</div>